generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Token {
  id              String          @id @default(uuid())
  chain           String
  chainId         Int
  contractAddress String
  deployer        String
  name            String
  symbol          String
  decimals        Int
  totalSupply     String
  discoveredAt    DateTime        @default(now())
  blockNumber     BigInt
  blockTimestamp  DateTime
  transactionHash String
  analysis        TokenAnalysis?
  watchEvents     WatchEvent[]

  @@unique([chain, contractAddress])
  @@index([chain])
  @@index([chainId])
  @@index([discoveredAt])
  @@index([chain, discoveredAt])
  @@index([name])
  @@index([symbol])
  @@index([deployer])
  @@index([blockNumber])
  @@map("tokens")
}

model TokenAnalysis {
  id                String   @id @default(uuid())
  tokenId           String   @unique
  token             Token    @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  riskScore         Int
  riskLevel         String
  explanation       String
  factors           Json
  analyzedAt        DateTime @default(now())
  ownerRenounced    Boolean  @default(false)
  mintable          Boolean  @default(false)
  pausable          Boolean  @default(false)
  blacklistFunction Boolean  @default(false)
  proxyContract     Boolean  @default(false)
  verifiedSource    Boolean  @default(false)
  buyTax            Int      @default(0)
  sellTax           Int      @default(0)
  liquidityLocked   Boolean  @default(false)
  liquidityPercent  Int      @default(0)
  holderCount       Int      @default(0)
  top10HolderPercent Int     @default(0)
  top1HolderPercent  Int     @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([riskScore])
  @@index([riskLevel])
  @@index([riskLevel, riskScore])
  @@map("token_analyses")
}

model WatchEvent {
  id        String   @id @default(uuid())
  tokenId   String
  token     Token    @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  eventType String
  message   String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([tokenId])
  @@index([eventType])
  @@map("watch_events")
}

model SyncCursor {
  id          String   @id
  chain       String
  blockNumber BigInt
  updatedAt   DateTime @updatedAt

  @@unique([id, chain])
  @@map("sync_cursors")
}
