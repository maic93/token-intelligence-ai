generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Token {
  id              String          @id @default(uuid())
  chain           String
  chainId         Int
  contractAddress String
  deployer        String
  name            String
  symbol          String
  decimals        Int
  totalSupply     String
  metadataConfidence Int       @default(100)
  isB20           Boolean         @default(false)
  b20Confidence   Int             @default(0)
  deployerReputation Int         @default(0)
  deployerGrade   String          @default("Unknown")
  aiCategory       String          @default("UNKNOWN")
  aiRecommendation String         @default("CAUTION")
  aiConfidence     Int             @default(0)
  aiSummary        String          @default("")
  discoveredAt    DateTime        @default(now())
  blockNumber     BigInt
  blockTimestamp  DateTime
  transactionHash String
  analysis        TokenAnalysis?
  watchEvents     WatchEvent[]
  fundedBy                String?
  fundingAmount           String?
  fundingTimestamp        DateTime?
        fundingSourceType       String   @default("Unknown")
  timeToDeploymentMinutes Float?
  signal              Signal?

  @@unique([chain, contractAddress])
  @@index([chain])
  @@index([chainId])
  @@index([discoveredAt])
  @@index([chain, discoveredAt])
  @@index([name])
  @@index([symbol])
  @@index([deployer])
  @@index([blockNumber])
  @@index([isB20, b20Confidence])
  @@map("tokens")
}

model TokenAnalysis {
  id                String   @id @default(uuid())
  tokenId           String   @unique
  token             Token    @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  riskScore         Int
  riskLevel         String
  explanation       String
  factors           Json
  analyzedAt        DateTime @default(now())
  ownerRenounced    Boolean  @default(false)
  mintable          Boolean  @default(false)
  pausable          Boolean  @default(false)
  blacklistFunction Boolean  @default(false)
  proxyContract     Boolean  @default(false)
  verifiedSource    Boolean  @default(false)
  buyTax            Int      @default(0)
  sellTax           Int      @default(0)
  liquidityLocked   Boolean  @default(false)
  liquidityPercent  Int      @default(0)
  holderCount       Int      @default(0)
  top10HolderPercent Int     @default(0)
  top1HolderPercent  Int     @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([riskScore])
  @@index([riskLevel])
  @@index([riskLevel, riskScore])
  @@map("token_analyses")
}

model WatchEvent {
  id        String   @id @default(uuid())
  tokenId   String
  token     Token    @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  eventType String
  message   String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([tokenId])
  @@index([eventType])
  @@map("watch_events")
}

model DeployerAnalytics {
  id                    String   @id @default(uuid())
  wallet                String   @unique
  tokensCreated         Int      @default(0)
  highRiskTokens        Int      @default(0)
  mediumRiskTokens      Int      @default(0)
  lowRiskTokens         Int      @default(0)
  avgRiskScore          Float?
  avgMetadataConfidence Float    @default(0)
  avgB20Confidence      Float    @default(0)
  firstSeen             DateTime?
  lastSeen              DateTime?
  uniqueSymbols         Int      @default(0)
  reputationScore       Int      @default(50)
  reputationGrade       String   @default("Average")
  updatedAt             DateTime @updatedAt

  @@index([reputationScore])
  @@index([tokensCreated])
  @@map("deployer_analytics")
}

model WalletProfile {
  id                    String   @id @default(uuid())
  wallet                String   @unique
  walletAgeDays         Int?
  firstSeen             DateTime?
  lastSeen              DateTime?
  totalDeployments      Int      @default(0)
  successfulTokens      Int      @default(0)
  highRiskTokens        Int      @default(0)
  b20Tokens             Int      @default(0)
  averageRisk           Float?
  averageMetadataConfidence Float @default(0)
  averageAiConfidence   Float    @default(0)
  reputation            Int      @default(50)
  grade                 String   @default("Average")
  labels                Json     @default("[]")
  summary               String   @default("")
  updatedAt             DateTime @updatedAt

  @@index([reputation])
  @@index([grade])
  @@index([totalDeployments])
  @@index([lastSeen])
  @@map("wallet_profiles")
}

model SyncCursor {
  id          String   @id
  chain       String
  blockNumber BigInt
  updatedAt   DateTime @updatedAt

  @@unique([id, chain])
  @@map("sync_cursors")
}

model AnalyticsSnapshot {
  id                       String   @id @default(uuid())
  period                   String
  timestamp                DateTime
  tokensIndexed            Int      @default(0)
  highRiskTokens           Int      @default(0)
  averageRisk              Float?
  averageMetadataConfidence Float?
  averageAIConfidence      Float?
  uniqueDeployers          Int      @default(0)
  totalDeployments         Int      @default(0)
  averageSmartMoneyScore   Float?
  eliteWallets             Int      @default(0)
  professionalWallets      Int      @default(0)
  dangerousWallets         Int      @default(0)
  averageFundingAmount     Float?
  cexFundedDeployers       Int      @default(0)
  bridgeFundedDeployers    Int      @default(0)
  largestFunding           Float?
  largestCluster           Int      @default(0)
  createdAt                DateTime @default(now())

  @@unique([period, timestamp])
  @@index([period])
  @@index([timestamp])
  @@map("analytics_snapshots")
}

model CategoryTrend {
  id              String   @id @default(uuid())
  category        String
  period          String
  timestamp       DateTime
  tokensIndexed   Int      @default(0)
  averageRisk     Float?
  averageConfidence Float?
  uniqueDeployers Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([category, period, timestamp])
  @@index([category])
  @@index([period])
  @@index([timestamp])
  @@map("category_trends")
}

model ChainTrend {
  id                    String   @id @default(uuid())
  chain                 String
  period                String
  timestamp             DateTime
  tokensIndexed         Int      @default(0)
  averageRisk           Float?
  averageMetadataConfidence Float?
  averageAIConfidence   Float?
  averageDeployerReputation Float?
  uniqueDeployers       Int      @default(0)
  createdAt             DateTime @default(now())

  @@unique([chain, period, timestamp])
  @@index([chain])
  @@index([period])
  @@index([timestamp])
  @@map("chain_trends")
}

model FundingProfile {
  wallet                  String   @id
  fundedBy                String?
  fundingTxHash           String?
  fundingBlock            BigInt?
  fundingTimestamp        DateTime?
  fundingAmount           String?
  fundingCurrency         String   @default("ETH")
  timeToDeploymentMinutes Float?
  fundingSourceType       String   @default("Unknown")
  clusterId               String?
  firstSeen               DateTime?
  updatedAt               DateTime @updatedAt

  @@index([fundedBy])
  @@index([fundingSourceType])
  @@index([clusterId])
  @@index([fundingTimestamp])
  @@map("funding_profiles")
}

model FundingCluster {
  id              String   @id @default(uuid())
  funderWallet    String
  walletCount     Int      @default(0)
  deployments     Int      @default(0)
  successfulTokens Int     @default(0)
  highRiskTokens  Int      @default(0)
  chains          Json     @default("[]")
  totalFunding    String   @default("0")
  firstSeen       DateTime?
  lastSeen        DateTime?
  updatedAt       DateTime @updatedAt

  @@index([funderWallet])
  @@index([walletCount])
  @@index([deployments])
  @@map("funding_clusters")
}

model Signal {
  id              String   @id @default(uuid())
  tokenId         String   @unique
  token           Token    @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  signal          String
  rating          String
  headline        String
  summary         String
  strengths       Json     @default("[]")
  weaknesses      Json     @default("[]")
  reasons         Json     @default("[]")
  recommendation  String
  opportunityScore Int     @default(0)
  riskScore       Int      @default(0)
  confidence      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([signal])
  @@index([rating])
  @@index([confidence])
  @@index([opportunityScore])
  @@index([riskScore])
  @@index([createdAt])
  @@map("signals")
}

model SmartMoneyProfile {
  id                    String   @id @default(uuid())
  wallet                String   @unique
  score                 Int      @default(0)
  grade                 String   @default("Dangerous")
  firstSeen             DateTime?
  lastSeen              DateTime?
  tokensCreated         Int      @default(0)
  averageRisk           Float?
  averageMetadataConfidence Float @default(0)
  averageAIConfidence   Float    @default(0)
  successfulTokens      Int      @default(0)
  failedTokens          Int      @default(0)
  averageHoldTimeDays   Float?
  winRate               Float    @default(0)
  labels                Json     @default("[]")
  summary               String   @default("")
  updatedAt             DateTime @updatedAt
  signals               Json     @default("[]")

  @@index([score])
  @@index([grade])
  @@index([winRate])
  @@index([tokensCreated])
  @@index([lastSeen])
  @@map("smart_money_profiles")
}

model WalletEdge {
  id              String   @id @default(uuid())
  fromWallet      String
  toWallet        String
  chain           String
  tokenAddress    String?
  currency        String   @default("ETH")
  amount          String
  amountUsd       Float?
  blockNumber     BigInt
  timestamp       DateTime
  transactionHash String
  edgeType        String
  confidence      Int      @default(50)
  createdAt       DateTime @default(now())

  @@index([fromWallet])
  @@index([toWallet])
  @@index([chain])
  @@index([timestamp])
  @@index([edgeType])
  @@index([fromWallet, toWallet])
  @@index([fromWallet, chain])
  @@index([toWallet, chain])
  @@map("wallet_edges")
}

model WalletCluster {
  id        String   @id @default(uuid())
  clusterId String
  wallet    String
  role      String   @default("member")
  score     Int      @default(0)
  depth     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([clusterId])
  @@index([wallet])
  @@index([clusterId, wallet])
  @@map("wallet_clusters")
}

model DeployerTrend {
  id                    String   @id @default(uuid())
  wallet                String
  period                String
  timestamp             DateTime
  tokensIndexed         Int      @default(0)
  averageRisk           Float?
  averageMetadataConfidence Float?
  averageAIConfidence   Float?
  reputation            Int      @default(50)
  createdAt             DateTime @default(now())

  @@unique([wallet, period, timestamp])
  @@index([wallet])
  @@index([period])
  @@index([timestamp])
  @@map("deployer_trends")
}
