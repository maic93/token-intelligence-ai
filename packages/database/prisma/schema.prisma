generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Token {
  id              String          @id @default(uuid())
  chain           String
  chainId         Int
  contractAddress String
  deployer        String
  name            String
  symbol          String
  decimals        Int
  totalSupply     String
  discoveredAt    DateTime        @default(now())
  blockNumber     BigInt
  blockTimestamp  DateTime
  transactionHash String
  analysis        TokenAnalysis?

  @@unique([chain, contractAddress])
  @@index([chain])
  @@index([chainId])
  @@index([discoveredAt])
  @@map("tokens")
}

model TokenAnalysis {
  id          String   @id @default(uuid())
  tokenId     String   @unique
  token       Token    @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  riskScore   Int
  riskLevel   String
  explanation String
  factors     Json
  analyzedAt  DateTime @default(now())

  @@index([riskScore])
  @@index([riskLevel])
  @@map("token_analyses")
}

model SyncCursor {
  id          String   @id
  chain       String
  blockNumber BigInt
  updatedAt   DateTime @updatedAt

  @@unique([id, chain])
  @@map("sync_cursors")
}
