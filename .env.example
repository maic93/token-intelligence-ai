# ==========================================
# Token Intelligence AI — Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ==========================================

# ─── General ───────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── PostgreSQL ────────────────────────────────────────
# Required. Connection string for the token database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/token_intelligence

# ─── Redis ─────────────────────────────────────────────
# Required for caching and WebSocket pub/sub.
# The API uses this for token caching and live event broadcasting.
# The Analytics engine uses this for report caching (5min TTL).
REDIS_URL=redis://localhost:6379

# ─── API ───────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── Indexer ───────────────────────────────────────────
# Block to start indexing from. 0 = latest block.
START_BLOCK=0
# Number of recent blocks to backfill on first run. 0 = none.
BACKFILL_BLOCKS=0
# How often to poll for new blocks (milliseconds). Minimum 1000.
POLL_INTERVAL_MS=12000

# ─── Chain RPC URLs ────────────────────────────────────
# Set the RPC URL for each chain you want to index.
# Chains without a URL are automatically disabled.
BASE_RPC_URL=https://mainnet.base.org
ETHEREUM_RPC_URL=https://eth.merkle.io
POLYGON_RPC_URL=https://polygon-rpc.com
# ROBINHOOD_RPC_URL=

# ─── Production Overrides ──────────────────────────────
# These are typically set by the production environment,
# not in .env.
# POSTGRES_PASSWORD=changeme
# POSTGRES_USER=postgres
# POSTGRES_DB=token_intelligence
